public class Main {
    public static void main(String[] args) {

        int[] arr = {10, 20, 30, 4, 5, 6};

        for (int i = 0; i < arr.length; i++) {

            if (i % 2 == 0) {      // Even index
                arr[i] += 10;
            } else {               // Odd index
                arr[i] *= 2;
            }
        }

        
        for (int num : arr) {
            System.out.print(num + " ");
        }
    }
}
