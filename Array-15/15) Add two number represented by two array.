int[] arr1={3,5,2,0,7};
int[] arr2={9,2,1};

int n1=arr1.length;
int n2=arr2.length;

int[] result=new int [Math.max(n1, n2) + 1];

int i=n1-1;
int j=n2-1;
int k=result.length-1;

int carry=0;

while(i>=0 || j>=0 || carry!=0){
int sum=carry;
if(i>=0)
sum += arr1[i--];
if(j>=0)
sum += arr2[j--];
result[k--]=sum%10;
carry=sum/10;
}
if(result[0]==0){
for(int p=1;p<result.length;p++)
sout(result[p]);
}else {
for(int p: result)
sout(p);
}}}
